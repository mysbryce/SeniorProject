  "productName": "Rose Chat",
  "version": "0.1.0",
  "identifier": "com.rose.chat",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web",
    "devUrl": null
  },
  "app": {
